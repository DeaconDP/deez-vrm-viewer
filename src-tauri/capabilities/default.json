{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop capabilities for Deez VRM Viewer",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "dialog:default",
    "opener:default",
    "allow-read-model-file",
    "allow-take-pending-model-path",
    "allow-write-export-file"
  ]
}
