{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Deez VRM Viewer",
  "version": "1.0.0",
  "identifier": "io.worldbuild.deez-vrm-viewer",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5188",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:desktop"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Deez VRM Viewer",
        "width": 1440,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "backgroundColor": "#121417"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["vrm", "glb", "gltf"],
        "name": "3D model",
        "description": "VRM or glTF 3D model",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
